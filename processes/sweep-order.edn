;;
;; The evaluation-order teaching process (spec/ChaoticFixpoint.tla): :d
;; negates :c from a strictly LATER stratum, so ADR 0005's linter accepts
;; it — yet the reached set is only deterministic because derivation uses
;; synchronous sweeps: :c enters at sweep 2, :d first becomes
;; prerequisite-enabled at sweep 3 and finds :c already decided. Correct
;; derivation of this process yields #{:a :b :c}, never :d; an evaluator
;; that fires one stage at a time can reach :d and is non-conformant.
;; The corpus case sweep-order-negation pins this byte-for-byte.
{:process/id :sweep-order
 :process/version 1
 :process/guard-vocab 1

 :process/stages
 [{:stage/id :a :guards []}
  {:stage/id :b :after [:a] :guards []}
  {:stage/id :c :after [:a] :guards []}
  {:stage/id :d :after [:b] :guards [[:not [:stage-reached :c]]]}]}
