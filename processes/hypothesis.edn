;;
;; The roadmap method (PLAN §16) as a process: a hypothesis is stated
;; with its kill criterion before any work, runs as a named experiment,
;; and ends validated OR killed — both sticky terminals, both requiring
;; evidence, because a killed hypothesis is a result, not a failure.
;; There is no way to reach a verdict without having stated, in advance
;; and on the record, what would count as losing.
{:process/id :hypothesis
 :process/version 1
 :process/guard-vocab 1

 :process/roles
 {:maintainer {:members ["seb"]}}

 :process/facts
 {[:statement]  [:string {:min 12}]
  [:kill]       [:string {:min 12}]
  [:experiment] [:string {:min 12}]
  [:verdict]    [:enum :validated :killed]
  [:evidence]   [:string {:min 8}]}

 :process/stages
 [{:stage/id :captured
   :hint "kb/runbooks/hypothesis-captured.md"
   :guards []}

  {:stage/id :stated
   :after [:captured]
   :hint "kb/runbooks/hypothesis-stated.md"
   :guards [[:fact [:statement]]
            [:fact [:kill]]
            [:signed-by :maintainer [:statement]]]}

  {:stage/id :running
   :hint "kb/runbooks/hypothesis-running.md"
   :after [:stated]
   :guards [[:fact [:experiment]]]}

  {:stage/id :validated
   :hint "kb/runbooks/hypothesis-validated.md"
   :after [:running]
   :stage/sticky? true
   :guards [[:fact= [:verdict] :validated]
            [:fact [:evidence]]]}

  {:stage/id :killed
   :hint "kb/runbooks/hypothesis-killed.md"
   :after [:running]
   :stage/sticky? true
   :guards [[:fact= [:verdict] :killed]
            [:fact [:evidence]]]}]}
